# =============================================================================
# Root voice / streaming server (Twilio + OpenAI + tools)
# Copy to .env and fill in. Never commit real .env files.
# =============================================================================

PORT=3000
# Public URL Twilio uses to reach this server (https in production)
PUBLIC_BASE_URL=

# Optional: ring delay before AI stream connects (seconds)
RING_DELAY_SECONDS=5

# --- Twilio (voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Optional tool APIs (leave blank to disable those tools) ---
OPENWEATHER_API_KEY=
API_FOOTBALL_KEY=
AVIATIONSTACK_API_KEY=
ALPHAVANTAGE_API_KEY=

# --- Transcript email (SMTP) ---
# Recipients: active subscribers get the email stored in the DB for the matching phone line (via platform caller-check).
# Trial/anonymous callers fall back to EMAIL_TO (optional if you only use subscribers and always have a line email).
EMAIL_FROM=
# Optional display name in the From header (e.g. BuddyCallAI)
# SMTP_FROM_NAME=
EMAIL_TO=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# =============================================================================
# Platform API (BuddyCallAI accounts, billing, usage deduction, call history)
# Required for: per-caller free trial (60s), subscriber balance, auto hangup, SMS alerts.
# =============================================================================
PLATFORM_API_BASE_URL=http://localhost:4000
INTEGRATION_WEBHOOK_SECRET=fYFZwACDIkpTb5hWx614NdXznPgJVrL0yl89Bi3GMUSoQmaH
USAGE_WEBHOOK_SECRET=5gFkNTPqZHj1Q7cewp9BJtXEUodrvOnM0Vzm4YRhSLCisayb
